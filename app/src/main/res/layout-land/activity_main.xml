<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Katalog Film"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212529"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/inputCari"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Cari judul film..."
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCari"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cari Film"
            android:backgroundTint="#0D6EFD"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSortAZ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Urutkan A - Z"
            style="?android:attr/buttonBarButtonStyle"
            android:backgroundTint="#E9ECEF"
            android:textColor="#495057"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSortZA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Urutkan Z - A"
            style="?android:attr/buttonBarButtonStyle"
            android:backgroundTint="#E9ECEF"
            android:textColor="#495057"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:background="#FFFFFF"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/wadahListFilm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        </LinearLayout>
    </ScrollView>

</LinearLayout>